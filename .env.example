# ============================================================
# SOC Mentor - Configuration
# Copiez ce fichier en .env et remplissez les valeurs réelles
# Ne commitez jamais votre .env (déjà dans .gitignore)
# ============================================================

# --- Claude API (obligatoire) ---
ANTHROPIC_API_KEY=sk-ant-votre-cle-ici

# --- OpenSearch / Wazuh Indexer ---
# Tunnel SSH requis : ssh -L 9200:127.0.0.1:9200 msh@172.16.1.10 -N
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=votre-mot-de-passe-admin

# --- Application ---
APP_HOST=0.0.0.0
APP_PORT=5001
