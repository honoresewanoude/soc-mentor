# ── Claude API ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Wazuh SSH ────────────────────────────────────────────────
# WAZUH_USER = utilisateur SSH sur le serveur Wazuh (pas l'API REST)
WAZUH_URL=https://172.16.1.10
WAZUH_USER=your-wazuh-ssh-user
WAZUH_PASSWORD=your-wazuh-password

# Chemin de la clé SSH DANS le conteneur (monté via docker-compose volume)
# Ne changez pas cette valeur sauf si vous modifiez le volume dans docker-compose.yml
SSH_KEY_PATH=/app/id_rsa

# ── Application ──────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=5001
